{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "strict":            true,
    "noUnusedLocals":    true,
    "noUnusedParameters":true,
    "noImplicitReturns": true,
    "skipLibCheck":      true,
    "outDir":            "../dist/frontend"
  },
  "include": ["src", "index.html"]
}
